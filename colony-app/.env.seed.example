# .env.seed.example — copy to .env.seed and fill in real values
# NEVER commit .env.seed to git — it contains private keys

# ── Bot wallet private keys (Base Sepolia) ────────────────────────────────────
# Generate 5 fresh wallets, fund each with ~0.02 ETH from:
#   https://www.alchemy.com/faucets/base-sepolia
#
# Each wallet will be registered as a named citizen:
#   BOT_0 = Alice   BOT_1 = Bob   BOT_2 = Charlie   BOT_3 = Diana   BOT_4 = Erik
#
BOT_0_KEY=0x...
BOT_1_KEY=0x...
BOT_2_KEY=0x...
BOT_3_KEY=0x...
BOT_4_KEY=0x...

# ── Supabase (same values as your Vercel environment) ─────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
