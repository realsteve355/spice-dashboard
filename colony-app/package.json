{
  "name": "spice-colony-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5174",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build",
    "seed": "node --env-file=.env.seed scripts/seed.js",
    "seed:reset": "node --env-file=.env.seed scripts/seed.js --reset",
    "seed:election": "node --env-file=.env.seed scripts/seed.js --election",
    "seed:dry": "node --env-file=.env.seed scripts/seed.js --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "ethers": "^6.16.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1"
  },
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^5.1.1",
    "jsdom": "^29.0.2",
    "vite": "^6.3.0",
    "vitest": "^4.1.5"
  }
}
